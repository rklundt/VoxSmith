{
  "name": "voxsmith",
  "version": "0.7.4",
  "description": "Desktop voice processing application for indie game developers",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --config electron-builder.config.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "postinstall": "tsx scripts/copy-binaries.ts"
  },
  "keywords": [
    "electron",
    "audio",
    "voice",
    "game-dev"
  ],
  "author": "",
  "license": "GPL-2.0",
  "type": "module",
  "dependencies": {
    "koffi": "^2.15.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rubberband-web": "^0.2.1",
    "tone": "^15.1.22",
    "wavesurfer.js": "^7.12.5",
    "winston": "^3.19.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@jitsi/rnnoise-wasm": "^0.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "ffmpeg-static",
      "esbuild",
      "electron-winstaller"
    ]
  }
}
