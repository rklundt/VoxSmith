*.exe
*.dmg
*.AppImage
*.snap

# OS files
.DS_Store
Thumbs.db

# Test
testResults/
coverage/
.vitest-cache/

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# Editor / local
*.local
