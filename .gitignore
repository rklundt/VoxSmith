# Dependencies
node_modules/
package-lock.json

# Build output
dist/
out/
release/

# Bundled binaries (fetched via postinstall, not committed)
src/assets/ffmpeg/
src/assets/rubberband-wasm/

# Logs
logs/
*.log

# User settings (override file only — settings.json is committed as defaults)
config/userSettingsOverride.json

# User data
userData/

# Portrait images (user-specific, copied via preset system)
portraits/*
!portraits/.gitkeep

# Environment
.env
.env.*

# Installers and binaries
*.exe
*.dmg
*.AppImage
*.snap

# Rubber Band assets: all binaries and support files are committed to git.
# Users cannot compile these locally — they must ship with the repo.
# These ! rules MUST come after *.exe above to override the global ignore.
!src/assets/rubberband/rubberband.exe
!src/assets/rubberband/rubberband-r3.exe
!src/assets/rubberband/rubberband-3.dll
!src/assets/rubberband/sndfile.dll
!src/assets/rubberband/CHANGELOG.txt
!src/assets/rubberband/COPYING.txt
!src/assets/rubberband/README.txt

# OS files
.DS_Store
Thumbs.db

# Test
testResults/
coverage/
.vitest-cache/

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# Editor / local
*.local
